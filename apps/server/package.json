{
  "name": "@arcadestrike/server",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "jest",
    "test:ci": "jest --runInBand --ci",
    "load:websocket": "node scripts/load/websocket-load.cjs",
    "load:matchmaking": "node scripts/load/matchmaking-throughput.cjs",
    "load:redis": "node scripts/load/redis-queue-stress.cjs",
    "load:replay": "node scripts/load/replay-persistence-stress.cjs",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@arcadestrike/shared": "*",
    "@colyseus/monitor": "^0.17.8",
    "@colyseus/schema": "^2.0.23",
    "colyseus": "^0.15.21",
    "dotenv": "^16.4.1",
    "ethers": "^6.10.0",
    "express": "^4.18.3",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^3.3.7",
    "pino": "^8.18.0",
    "@prisma/client": "^5.22.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "ts-jest": "^29.1.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
