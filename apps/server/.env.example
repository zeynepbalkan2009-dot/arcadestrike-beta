# ArcadeStrike Server — Environment Variables
NODE_ENV=development
PORT=2567
CLIENT_ORIGIN=http://localhost:5173

# PostgreSQL
DATABASE_URL=postgresql://arcadestrike:arcadestrike@localhost:5432/arcadestrike?schema=public

# Blockchain
RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
ORACLE_PRIVATE_KEY=0x... # HSM-backed in production — NEVER commit this
ESCROW_ADDRESS=0x...
TOKEN_ADDRESS=0x...

# Optional Redis (required for multi-instance)
# REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info
