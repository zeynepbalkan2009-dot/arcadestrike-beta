# ArcadeStrike Client — Environment Variables
# Copy to .env.local for local dev

# Server WebSocket URL (Colyseus)
VITE_SERVER_URL=ws://localhost:2567

# REST API base
VITE_API_URL=http://localhost:2567

# Blockchain (Polygon)
VITE_CHAIN_ID=137
VITE_ESCROW_ADDRESS=0xYOUR_ESCROW_ADDRESS
VITE_TOKEN_ADDRESS=0xYOUR_TOKEN_ADDRESS

# Optional: WalletConnect project ID
VITE_WALLETCONNECT_PROJECT_ID=
